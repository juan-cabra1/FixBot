# FixBot — Environment variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Gemini AI ──────────────────────────────────────────────
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── WhatsApp (Whapi.cloud) ─────────────────────────────────
# Get at: https://whapi.cloud
WHAPI_TOKEN=
WHAPI_API_URL=https://gate.whapi.cloud
WHAPI_HOOK_TOKEN=   # Optional: set in Whapi dashboard → Settings → Webhooks → Hook Token

# ── Database ───────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./fixbot.db
# Production (Railway PostgreSQL — use the interpolated URL):
# DATABASE_URL=${Postgres.DATABASE_URL}

# ── Server ─────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development   # development | production

# ── Frontend (CORS) ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Debounce ───────────────────────────────────────────────
DEBOUNCE_SECONDS=6
